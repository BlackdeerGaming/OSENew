# --- CONFIGURACIÓN DE BACKEND ---

# OpenRouter API Key (Obtenla en https://openrouter.ai/)
OPENROUTER_API_KEY=tu_api_key_aqui

# OpenRouter Modelo (Ej: google/gemini-2.0-flash-001)
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# --- CONFIGURACIÓN DE PINECONE (Vector DB) ---
# Crea tu índice con DIMENSIÓN 384 (Métrica: Cosine)
PINECONE_API_KEY=tu_api_key_de_pinecone
PINECONE_INDEX_NAME=nombre_de_tu_indice

# --- CONFIGURACIÓN DE FRONTEND ---
# (Vite usa VITE_ en el cliente si es necesario)
VITE_API_URL=http://localhost:8000
