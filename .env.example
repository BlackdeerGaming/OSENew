# --- CONFIGURACIÓN DE BACKEND ---

# OpenRouter API Key (Obtenla en https://openrouter.ai/)
OPENROUTER_API_KEY=tu_api_key_aqui

# Modelo de Texto Sugerido (Ej: google/gemini-2.0-flash-001 o qwen/qwen-2.5-72b-instruct)
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# --- CONFIGURACIÓN DE FRONTEND ---
# (Vite usa VITE_ en el cliente si es necesario)
VITE_API_URL=http://localhost:8000
